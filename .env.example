# -----------------------------------------------------------------------------
# Purpose: Example environment variables used by docker-compose services.
# Usage  : cp .env.example .env  — then fill in the blank values.
# -----------------------------------------------------------------------------

# Airflow
# On Linux, set to your user id: AIRFLOW_UID=$(id -u)
AIRFLOW_UID=1000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://<user>:<pass>@postgres:5432/airflow_db
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AIRFLOW__WEBSERVER__SECRET_KEY=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_EMAIL=admin@example.com

# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_AIRFLOW_DB=airflow_db
POSTGRES_WAREHOUSE_DB=warehouse_db
POSTGRES_METABASE_DB=metabase_db

# Metabase
MB_DB_DBNAME=metabase_db
MB_DB_USER=
MB_DB_PASS=
MB_DB_HOST=postgres
MB_DB_PORT=5432
# Source Database (OLTP)
OLTP_HOST=
OLTP_PORT=5432
OLTP_DBNAME=olap_db
OLTP_USER=
OLTP_PASSWORD=
