# -----------------------------------------------------------------------------
# Purpose: Ignore local secrets, runtime artifacts, caches, and build outputs.
# -----------------------------------------------------------------------------

# Secrets
.env

# Airflow logs
logs/

# Python cache/artifacts
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Type checker / linter caches
.mypy_cache/
.ruff_cache/
.idea/

# Build outputs
dist/

# OS / editor artifacts
.DS_Store

# Runtime files
*.log
*.pid

# Optional virtual environments
.venv/
venv/
